# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gdrive/callback

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=TandemLog <onboarding@resend.dev>

# Owner notifications (Drive access requests)
# Where to ping when someone wants to connect Google Drive and needs to be
# whitelisted as a Google test user. Email works out of the box via Resend;
# WhatsApp needs a free CallMeBot key (message the CallMeBot bot from your
# WhatsApp once to obtain it). Defaults: phone +41791242174, email owner gmail.
OWNER_NOTIFY_EMAIL=
OWNER_WHATSAPP_PHONE=
CALLMEBOT_API_KEY=

# Cron / server secrets
CRON_SECRET=

# Self-signup gate
# Shared invite code pilots enter to register (rotate via WhatsApp).
SIGNUP_CODE=

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI screenshot capture (optional — simplified day capture)
ANTHROPIC_API_KEY=
# Optional model override (default claude-haiku-4-5)
AI_EXTRACT_MODEL=
